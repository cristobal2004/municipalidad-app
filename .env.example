# URL base del backend
VITE_API_URL=http://localhost:3000/api

# Puertos publicados por Docker Compose
FRONTEND_PORT=8080
BACKEND_PORT=3000
POSTGRES_PORT=5432

# Base de datos de Docker Compose
POSTGRES_DB=municipalidad_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_clave_de_base_de_datos

# Seguridad del backend (usa una cadena aleatoria de al menos 32 caracteres)
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
CORS_ORIGIN=http://localhost:8080

# Correo saliente (SMTP). Ejemplo para Gmail: smtp.gmail.com, puerto 465.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=correo_municipal@gmail.com
SMTP_PASS=clave_de_aplicacion
SMTP_FROM="Municipalidad de Santo Domingo <correo_municipal@gmail.com>"
SMTP_REPLY_TO=atencionciudadana@santodomingo.cl
