# URL base del backend
VITE_API_URL=http://localhost:3000/api

# Puertos publicados por Docker Compose
FRONTEND_PORT=8080
BACKEND_PORT=3000
POSTGRES_PORT=5432
MAILPIT_WEB_PORT=8025

# Base de datos de Docker Compose
POSTGRES_DB=municipalidad_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_clave_de_base_de_datos

# Seguridad del backend (usa una cadena aleatoria de al menos 32 caracteres)
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio
CORS_ORIGIN=http://localhost:8080

# Correo saliente. Estos valores usan Mailpit en Docker para probar entregas
# reales sin enviar mensajes a direcciones externas. Reemplázalos por el SMTP
# institucional al desplegar en producción.
EMAIL_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Municipalidad de Santo Domingo <no-responder@santodomingo.cl>"
SMTP_REPLY_TO=atencionciudadana@santodomingo.cl
