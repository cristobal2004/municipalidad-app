# Puerto del servidor backend
PORT=3000

# Configuración de PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=municipalidad_app
DB_USER=postgres
DB_PASSWORD=tu_password

# Configuración JWT
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio

CORS_ORIGIN=http://localhost:8080,http://localhost:5173
FERIADOS_CACHE_TTL_MS=3600000
FERIADOS_TIMEOUT_MS=5000

# Correo saliente (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=correo_municipal@gmail.com
SMTP_PASS=clave_de_aplicacion
SMTP_FROM="Municipalidad de Santo Domingo <correo_municipal@gmail.com>"
SMTP_REPLY_TO=atencionciudadana@santodomingo.cl
