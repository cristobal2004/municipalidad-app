# Puerto del servidor backend
PORT=3000

# Configuración de PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=municipalidad_app
DB_USER=postgres
DB_PASSWORD=tu_password

# Configuración JWT
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio

CORS_ORIGIN=http://localhost:8080,http://localhost:5173
FERIADOS_CACHE_TTL_MS=3600000
FERIADOS_TIMEOUT_MS=5000

# Correo saliente. Para ejecutar el backend fuera de Docker, configura un SMTP
# local o institucional. Docker Compose ya conecta automáticamente con Mailpit.
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Municipalidad de Santo Domingo <no-responder@santodomingo.cl>"
SMTP_REPLY_TO=atencionciudadana@santodomingo.cl
